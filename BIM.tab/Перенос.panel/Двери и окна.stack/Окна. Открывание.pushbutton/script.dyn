    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Загрузить стандартную библиотеку Python и библиотеку DesignScript\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# Введенные в этом узле данные сохраняется в виде списка в переменных IN.\r\nfamilies = IN[0]\r\nclapans = IN[1]\r\nclapansf = IN[2]\r\nok = 'Окн_Окн_'\r\nbb = 'Окн_ББлок_'\r\noutlist = []\r\n\r\n# Разместите код под этой строкой\r\nfor family, clapan, clapanf in zip(families, clapans, clapansf):\r\n\tif ok in family:\r\n\t\tif clapan == 0 and clapanf == 0:\r\n\t\t\toutlist.append('')\r\n\t\telif clapan == 0 and clapanf == 1:\r\n\t\t\toutlist.append('-к1ф')\r\n\t\telif clapan == 0 and clapanf == 2:\r\n\t\t\toutlist.append('-к2ф')\r\n\t\telif clapan == 1 and clapanf == 0:\r\n\t\t\toutlist.append('-к1')\r\n\t\telif clapan == 2 and clapanf == 0:\r\n\t\t\toutlist.append('-к2')\r\n\t\telif clapan == 1 and clapanf == 1:\r\n\t\t\toutlist.append('-к1ф')\r\n\t\telif clapan == 2 and clapanf == 1:\r\n\t\t\toutlist.append('-к2ф1')\r\n\t\telif clapan == 2 and clapanf == 2:\r\n\t\t\toutlist.append('-к2ф')\r\n\t\telif clapan == 1 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('-к1')\r\n\t\telif clapan == 2 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('-к2')\r\n\t\telif len(str(clapan)) == 0 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('')\r\n\t\telif clapan == 0 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('')\r\n\t\telif clapan == 1 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('-к1')\r\n\t\telif clapan == 2 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('-к2')\r\n\t\telif len(str(clapan)) == 0 and clapanf == 0:\r\n\t\t\toutlist.append('')\r\n\t\telif len(str(clapan)) == 0 and clapanf == 1:\r\n\t\t\toutlist.append('-к1ф')\r\n\t\telif len(str(clapan)) == 0 and clapanf == 2:\r\n\t\t\toutlist.append('-к2ф')\r\n\t\telse:\r\n\t\t\toutlist.append('')\r\n\telif bb in family:\r\n\t\tif clapan == 0 and clapanf == 0:\r\n\t\t\toutlist.append('Л')\r\n\t\telif clapan == 0 and clapanf == 1:\r\n\t\t\toutlist.append('Л-к1ф')\r\n\t\telif clapan == 0 and clapanf == 2:\r\n\t\t\toutlist.append('Л-к2ф')\r\n\t\telif clapan == 1 and clapanf == 0:\r\n\t\t\toutlist.append('Л-к1')\r\n\t\telif clapan == 2 and clapanf == 0:\r\n\t\t\toutlist.append('Л-к2')\r\n\t\telif clapan == 1 and clapanf == 1:\r\n\t\t\toutlist.append('Л-к1ф')\r\n\t\telif clapan == 2 and clapanf == 1:\r\n\t\t\toutlist.append('Л-к2ф1')\r\n\t\telif clapan == 2 and clapanf == 2:\r\n\t\t\toutlist.append('Л-к2ф')\r\n\t\telif clapan == 1 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('Л-к1')\r\n\t\telif clapan == 2 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('Л-к2')\r\n\t\telif len(str(clapan)) == 0 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('Л')\r\n\t\telif clapan == 0 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('Л')\r\n\t\telif clapan == 1 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('Л-к1')\r\n\t\telif clapan == 2 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('Л-к2')\r\n\t\telif len(str(clapan)) == 0 and clapanf == 0:\r\n\t\t\toutlist.append('Л')\r\n\t\telif len(str(clapan)) == 0 and clapanf == 1:\r\n\t\t\toutlist.append('Л-к1ф')\r\n\t\telif len(str(clapan)) == 0 and clapanf == 2:\r\n\t\t\toutlist.append('Л-к2ф')\r\n\t\telse:\r\n\t\t\toutlist.append('Л')\r\n\telse:\r\n\t\toutlist.append('')\r\n# Назначьте вывод переменной OUT.\r\nOUT = outlist",
