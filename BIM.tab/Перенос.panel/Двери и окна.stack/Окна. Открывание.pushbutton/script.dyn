    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Загрузить стандартную библиотеку Python и библиотеку DesignScript\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# Введенные в этом узле данные сохраняется в виде списка в переменных IN.\r\nclapans = IN[0]\r\nclapansf = IN[1]\r\noutlist = []\r\n\r\n# Разместите код под этой строкой\r\nfor clapan, clapanf in zip(clapans, clapansf):\r\n\tif clapan == 0 and clapanf == 0:\r\n\t\toutlist.append('')\r\n\telif clapan == 0 and clapanf == 1:\r\n\t\toutlist.append('к1ф - один клапан Air-Box Comfort S (с фрезеровкой)')\r\n\telif clapan == 0 and clapanf == 2:\r\n\t\toutlist.append('к2ф - два клапана Air-Box Comfort S (с фрезеровкой)')\r\n\telif clapan == 1 and clapanf == 0:\r\n\t\toutlist.append('к1 - один клапан Air-Box Comfort')\r\n\telif clapan == 2 and clapanf == 0:\r\n\t\toutlist.append('к2 - два клапана Air-Box Comfort')\r\n\telif clapan == 1 and clapanf == 1:\r\n\t\toutlist.append('к1ф - один клапан Air-Box Comfort S (с фрезеровкой)')\r\n\telif clapan == 2 and clapanf == 1:\r\n\t\toutlist.append('к2ф1 - два клапана Air-Box Comfort, один с фрезеровкой (Air-Box Comfort S)')\r\n\telif clapan == 2 and clapanf == 2:\r\n\t\toutlist.append('к2ф - два клапана Air-Box Comfort S (с фрезеровкой)')\r\n\telif clapan == 1 and len(str(clapanf)) == 0:\r\n\t\toutlist.append('к1 - один клапан Air-Box Comfort')\r\n\telif clapan == 2 and len(str(clapanf)) == 0:\r\n\t\toutlist.append('к2 - два клапана Air-Box Comfort')\r\n\telif len(str(clapan)) == 0 and len(str(clapanf)) == 0:\r\n\t\toutlist.append('')\r\n\telif clapan == 0 and len(str(clapanf)) == 0:\r\n\t\toutlist.append('')\r\n\telif clapan == 1 and len(str(clapanf)) == 0:\r\n\t\toutlist.append('к1 - один клапан Air-Box Comfort')\r\n\telif clapan == 2 and len(str(clapanf)) == 0:\r\n\t\toutlist.append('к2 - два клапана Air-Box Comfort')\r\n\telif len(str(clapan)) == 0 and clapanf == 0:\r\n\t\toutlist.append('')\r\n\telif len(str(clapan)) == 0 and clapanf == 1:\r\n\t\toutlist.append('к1ф - один клапан Air-Box Comfort S (с фрезеровкой)')\r\n\telif len(str(clapan)) == 0 and clapanf == 2:\r\n\t\toutlist.append('к2ф - два клапана Air-Box Comfort S (с фрезеровкой)')\r\n\telse:\r\n\t\toutlist.append('НЕТ ДАННЫХ')\r\n# Назначьте вывод переменной OUT.\r\nOUT = outlist",
      "Engine": "IronPython2",
      "VariableInputPorts": true,
      "Id": "a875052f080c415e991e993a374f5aae",
      "Inputs": [
        {
          "Id": "dbf436a7a134419e9fddfbd5142f94a9",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "4e786b9713b04aefa0066a73ffca8e98",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "541702a86cef4ee996e2b18ed5c413d3",
          "Name": "OUT",
          "Description": "Результат сценария Python",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Выполнение встроенного сценария Python."
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Загрузить стандартную библиотеку Python и библиотеку DesignScript\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# Введенные в этом узле данные сохраняется в виде списка в переменных IN.\r\nfamilies = IN[0]\r\nclapans = IN[1]\r\nclapansf = IN[2]\r\noutlist = []\r\n\r\n# Разместите код под этой строкой\r\nfor family, clapan, clapanf in zip(families, clapans, clapansf):\r\n\tif clapan == 0 and clapanf == 0:\r\n\t\toutlist.append('')\r\n\telif clapan == 0 and clapanf == 1:\r\n\t\toutlist.append('-к1ф')\r\n\telif clapan == 0 and clapanf == 2:\r\n\t\toutlist.append('-к2ф')\r\n\telif clapan == 1 and clapanf == 0:\r\n\t\toutlist.append('-к1')\r\n\telif clapan == 2 and clapanf == 0:\r\n\t\toutlist.append('-к2')\r\n\telif clapan == 1 and clapanf == 1:\r\n\t\toutlist.append('-к1ф')\r\n\telif clapan == 2 and clapanf == 1:\r\n\t\toutlist.append('-к2ф1')\r\n\telif clapan == 2 and clapanf == 2:\r\n\t\toutlist.append('-к2ф')\r\n\telif clapan == 1 and len(str(clapanf)) == 0:\r\n\t\toutlist.append('-к1')\r\n\telif clapan == 2 and len(str(clapanf)) == 0:\r\n\t\toutlist.append('-к2')\r\n\telif len(str(clapan)) == 0 and len(str(clapanf)) == 0:\r\n\t\toutlist.append('')\r\n\telif clapan == 0 and len(str(clapanf)) == 0:\r\n\t\toutlist.append('')\r\n\telif clapan == 1 and len(str(clapanf)) == 0:\r\n\t\toutlist.append('-к1')\r\n\telif clapan == 2 and len(str(clapanf)) == 0:\r\n\t\toutlist.append('-к2')\r\n\telif len(str(clapan)) == 0 and clapanf == 0:\r\n\t\toutlist.append('')\r\n\telif len(str(clapan)) == 0 and clapanf == 1:\r\n\t\toutlist.append('-к1ф')\r\n\telif len(str(clapan)) == 0 and clapanf == 2:\r\n\t\toutlist.append('-к2ф')\r\n\telse:\r\n\t\toutlist.append('')\r\n# Назначьте вывод переменной OUT.\r\nOUT = outlist",
