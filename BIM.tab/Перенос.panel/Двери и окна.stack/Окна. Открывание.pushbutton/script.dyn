    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import codecs\r\nimport os.path\r\n\r\npath = r\"T:\\Проектный институт\\Отдел стандартизации BIM и RD\\BIM-Ресурсы\\4-Dynamo\\Архив\\BIM-отдел\\Dynamo_new_report.py\"\r\n\r\nresult = \"\"\r\n\r\nif os.path.exists(path):\r\n\twith codecs.open(path, 'r', encoding=\"utf-8\") as file:\r\n\t\tfor line in file.readlines():\r\n\t\t\tresult += line\r\n\r\nOUT = result",
      "Engine": "IronPython2",
      "VariableInputPorts": true,
      "Id": "9085861d00a9455f8655178512ea7eb5",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "8648dcce11ee45b8baeafa09320dfbf8",
          "Name": "OUT",
          "Description": "Результат сценария Python",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Выполнение встроенного сценария Python."
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Загрузить стандартную библиотеку Python и библиотеку DesignScript\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# Введенные в этом узле данные сохраняется в виде списка в переменных IN.\r\nfamilies = IN[0]\r\nclapans = IN[1]\r\nclapansf = IN[2]\r\nok = 'Окн_Окн_'\r\nbb = 'Окн_ББлок_'\r\noutlist = []\r\n\r\n# Разместите код под этой строкой\r\nfor family, clapan, clapanf in zip(families, clapans, clapansf):\r\n\tif ok in family:\r\n\t\tif clapan == 0 and clapanf == 0:\r\n\t\t\toutlist.append('.1')\r\n\t\telif clapan == 0 and clapanf == 1:\r\n\t\t\toutlist.append('.1-к1ф')\r\n\t\telif clapan == 0 and clapanf == 2:\r\n\t\t\toutlist.append('.1-к2ф')\r\n\t\telif clapan == 1 and clapanf == 0:\r\n\t\t\toutlist.append('.1-к1')\r\n\t\telif clapan == 2 and clapanf == 0:\r\n\t\t\toutlist.append('.1-к2')\r\n\t\telif clapan == 1 and clapanf == 1:\r\n\t\t\toutlist.append('.1-к1ф')\r\n\t\telif clapan == 2 and clapanf == 1:\r\n\t\t\toutlist.append('.1-к2ф1')\r\n\t\telif clapan == 2 and clapanf == 2:\r\n\t\t\toutlist.append('.1-к2ф')\r\n\t\telif clapan == 1 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('.1-к1')\r\n\t\telif clapan == 2 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('.1-к2')\r\n\t\telif len(str(clapan)) == 0 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('.1')\r\n\t\telif clapan == 0 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('.1')\r\n\t\telif clapan == 1 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('.1-к1')\r\n\t\telif clapan == 2 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('.1-к2')\r\n\t\telif len(str(clapan)) == 0 and clapanf == 0:\r\n\t\t\toutlist.append('.1')\r\n\t\telif len(str(clapan)) == 0 and clapanf == 1:\r\n\t\t\toutlist.append('.1-к1ф')\r\n\t\telif len(str(clapan)) == 0 and clapanf == 2:\r\n\t\t\toutlist.append('.1-к2ф')\r\n\t\telse:\r\n\t\t\toutlist.append('.1')\r\n\telif bb in family:\r\n\t\tif clapan == 0 and clapanf == 0:\r\n\t\t\toutlist.append('')\r\n\t\telif clapan == 0 and clapanf == 1:\r\n\t\t\toutlist.append('-к1ф')\r\n\t\telif clapan == 0 and clapanf == 2:\r\n\t\t\toutlist.append('-к2ф')\r\n\t\telif clapan == 1 and clapanf == 0:\r\n\t\t\toutlist.append('-к1')\r\n\t\telif clapan == 2 and clapanf == 0:\r\n\t\t\toutlist.append('-к2')\r\n\t\telif clapan == 1 and clapanf == 1:\r\n\t\t\toutlist.append('-к1ф')\r\n\t\telif clapan == 2 and clapanf == 1:\r\n\t\t\toutlist.append('-к2ф1')\r\n\t\telif clapan == 2 and clapanf == 2:\r\n\t\t\toutlist.append('-к2ф')\r\n\t\telif clapan == 1 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('-к1')\r\n\t\telif clapan == 2 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('-к2')\r\n\t\telif len(clapan) == 0 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('')\r\n\t\telif clapan == 0 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('')\r\n\t\telif clapan == 1 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('-к1')\r\n\t\telif clapan == 2 and len(str(clapanf)) == 0:\r\n\t\t\toutlist.append('-к2')\r\n\t\telif len(str(clapan)) == 0 and clapanf == 0:\r\n\t\t\toutlist.append('')\r\n\t\telif len(str(clapan)) == 0 and clapanf == 1:\r\n\t\t\toutlist.append('-к1ф')\r\n\t\telif len(str(clapan)) == 0 and clapanf == 2:\r\n\t\t\toutlist.append('-к2ф')\r\n\t\telse:\r\n\t\t\toutlist.append('')\r\n\telse:\r\n\t\toutlist.append('')\r\n# Назначьте вывод переменной OUT.\r\nOUT = outlist",
      "Engine": "IronPython2",
      "VariableInputPorts": true,
      "Id": "11cdfad2599346aab497fc25fcb7b14b",
      "Inputs": [
