    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Загрузить стандартную библиотеку Python и библиотеку DesignScript\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# Введенные в этом узле данные сохраняется в виде списка в переменных IN.\r\nnames = IN[0]\r\nstl = 'Сталь'\r\nalm = 'Алюминий'\r\npvh = 'ПВХ'\r\ndrv = 'Дерево'\r\nodn = 'Однп'\r\ndvu = 'Двуп'\r\noutlist = []\r\n\r\n# Разместите код под этой строкой\r\nfor name in names:\r\n\tif stl in name and odn in name:\r\n\t\toutlist.append('Оп')\r\n\telif stl in name and dvu in name:\r\n\t\toutlist.append('Дп')\r\n\telif alm in name and odn in name:\r\n\t\toutlist.append('Оп')\r\n\telif alm in name and dvu in name:\r\n\t\toutlist.append('Дв')\r\n\telif pvh in name and odn in name:\r\n\t\toutlist.append('Оп')\r\n\telif pvh in name and dvu in name:\r\n\t\toutlist.append('Дп')\r\n\telif drv in name and odn in name:\r\n\t\toutlist.append('1')\r\n\telif drv in name and dvu in name:\r\n\t\toutlist.append('2')\r\n\telse:\r\n\t\toutlist.append('#')\r\n# Назначьте вывод переменной OUT.\r\nOUT = outlist",
      "Engine": "IronPython2",
      "VariableInputPorts": true,
      "Id": "2c437d2e655343a785358bcca0a84f27",
      "Inputs": [
        {
          "Id": "daa1661224544596ac94dc10e787fc98",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
