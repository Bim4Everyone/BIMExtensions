    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Загрузить стандартную библиотеку Python и библиотеку DesignScript\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# Введенные в этом узле данные сохраняется в виде списка в переменных IN.\r\nnames = IN[0]\r\nstl = 'Сталь'\r\nalm = 'Алюминий'\r\npvh = 'ПВХ'\r\ndrv = 'Дерево'\r\nprg0 = '_П0'\r\nprg1 = '_П1'\r\noutlist = []\r\n\r\n# Разместите код под этой строкой\r\nfor name in names:\r\n\tif stl in name and prg0 in name:\r\n\t\toutlist.append('Брг')\r\n\telif stl in name and prg1 in name:\r\n\t\toutlist.append('Прг')\r\n\telif alm in name and prg0 in name:\r\n\t\toutlist.append('Бпр')\r\n\telif alm in name and prg1 in name:\r\n\t\toutlist.append('П')\r\n\telif pvh in name and prg0 in name:\r\n\t\toutlist.append('Бпр')\r\n\telif pvh in name and prg1 in name:\r\n\t\toutlist.append('П')\r\n\telif drv in name and prg0 in name:\r\n\t\toutlist.append('ПрБ')\r\n\telif drv in name and prg1 in name:\r\n\t\toutlist.append('Пр')\r\n\telse:\r\n\t\toutlist.append('#')\r\n# Назначьте вывод переменной OUT.\r\nOUT = outlist",
      "Engine": "IronPython2",
      "VariableInputPorts": true,
      "Id": "b17f0986306646edb77c11cccfb8a175",
      "Inputs": [
