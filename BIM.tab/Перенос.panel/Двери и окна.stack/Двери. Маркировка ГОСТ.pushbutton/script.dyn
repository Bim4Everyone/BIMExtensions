    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Загрузить стандартную библиотеку Python и библиотеку DesignScript\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# Введенные в этом узле данные сохраняется в виде списка в переменных IN.\r\nnames = IN[0]\r\nglars = IN[1]\r\nmats = IN[2]\r\nstl = 'Сталь'\r\nalm = 'Алюминий'\r\nost = 'Двр_Плтн_Остекленное_!'\r\noutlist = []\r\n\r\n# Разместите код под этой строкой\r\nfor name, glar, mat in zip(names, glars, mats):\r\n\tif ost in name and glar >= 1.2 and stl in mat:\r\n\t\toutlist.append('остекленный (более 1.2 м²), ')\r\n\telif ost in name and glar >= 0.2 and glar < 1.2 and stl in mat:\r\n\t\toutlist.append('остекленный (более 0.2 м²), ')\r\n\telif ost in name and glar < 0.2 and stl in mat:\r\n\t\toutlist.append('остекленный (менее 0.2 м²), ')\r\n\telif ost in name and glar >= 1.2 and alm in mat:\r\n\t\toutlist.append('(более 1.2 м²), ')\r\n\telif ost in name and glar >= 0.2 and glar < 1.2 and alm in mat:\r\n\t\toutlist.append('(более 0.2 м²), ')\r\n\telif ost in name and glar < 0.2 and alm in mat:\r\n\t\toutlist.append('(менее 0.2 м²), ')\r\n\telif ost in name and not stl in mat and not alm in mat:\r\n\t\toutlist.append('ОСТЕКЛЕНИЕ НЕ ОПРЕДЕЛЕНО/')\r\n\telse:\r\n\t\toutlist.append('')\r\n# Назначьте вывод переменной OUT.\r\nOUT = outlist",
      "Engine": "IronPython2",
      "VariableInputPorts": true,
      "Id": "43bf507a7616445b8ef809e85bd77b91",
      "Inputs": [
