    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Загрузить стандартную библиотеку Python и библиотеку DesignScript\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# Введенные в этом узле данные сохраняется в виде списка в переменных IN.\r\nnames = IN[0]\r\nfires = IN[1]\r\ntypes = IN[2]\r\nstl = 'Сталь'\r\nalm = 'Алюминий'\r\noutlist = []\r\n\r\n# Разместите код под этой строкой\r\nfor name, fire , type in zip(names, fires, types):\r\n\tif name == '1' and 'EI' in fire and not 'W' in fire and not 'WS' in fire and not 'S' in fire and (stl in type or alm in type):\r\n\t\toutlist.append('с пределом огнестойкости ' + fire + ', ')\r\n\telif name == '1' and 'EI' in fire and 'W' in fire and (stl in type or alm in type):\r\n\t\toutlist.append('с пределом огнестойкости ' + fire + ', в дымогазонепроницаемом исполнении, ')\r\n\telif name == '1' and 'EI' in fire and 'S' in fire and (stl in type or alm in type):\r\n\t\toutlist.append('с пределом огнестойкости ' + fire + ', в дымогазонепроницаемом исполнении, ')\r\n\telif name == '1' and (not stl in name or not alm in name):\r\n\t\toutlist.append('ОГНЕСТОЙКОСТЬ НЕ ОПРЕДЕЛЕНА/')\r\n\telse:\r\n\t\toutlist.append('')\r\n# Назначьте вывод переменной OUT.\r\nOUT = outlist",
