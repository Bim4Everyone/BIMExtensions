    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Загрузить стандартную библиотеку Python и библиотеку DesignScript\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# Введенные в этом узле данные сохраняется в виде списка в переменных IN.\r\nnames = IN[0]\r\npp = 'ПП'\r\nstl = 'Сталь'\r\nalm = 'Алюминий'\r\npvh = 'ПВХ'\r\ndrv = 'Дерево'\r\noutlist = []\r\n\r\n# Разместите код под этой строкой\r\nfor name in names:\r\n\tif stl in name and not pp in name:\r\n\t\toutlist.append('ГОСТ 31173-2016')\r\n\telif stl in name and pp in name:\r\n\t\toutlist.append('ГОСТ Р 57327-2016')\r\n\telif alm in name and not pp in name:\r\n\t\toutlist.append('ГОСТ 23747-2015')\r\n\telif alm in name and pp in name:\r\n\t\toutlist.append('ГОСТ 23747-2015')\r\n\telif drv in name:\r\n\t\toutlist.append('ГОСТ 475-2016')\r\n\telif pvh in name:\r\n\t\toutlist.append('ГОСТ 30970-2014')\r\n\telse:\r\n\t\toutlist.append('ГОСТ НЕ НАЙДЕН')\r\n# Назначьте вывод переменной OUT.\r\nOUT = outlist",
      "Engine": "IronPython2",
      "VariableInputPorts": true,
      "Id": "10e9d395fc264d1ea8e4157dd6b93390",
      "Inputs": [
        {
          "Id": "6bbc965a45594ccca4232fa77c33cad6",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "3adc383af8af44b69f5081da2f9adcbc",
          "Name": "OUT",
          "Description": "Результат сценария Python",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
