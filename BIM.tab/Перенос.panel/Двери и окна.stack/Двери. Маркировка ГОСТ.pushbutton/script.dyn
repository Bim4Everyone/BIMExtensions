    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Загрузить стандартную библиотеку Python и библиотеку DesignScript\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# Введенные в этом узле данные сохраняется в виде списка в переменных IN.\r\nnames = IN[0]\r\npp = 'ПП'\r\nstl = 'Сталь'\r\nalm = 'Алюминий'\r\npvh = 'ПВХ'\r\ndrv = 'Дерево'\r\ndv = 'ДВ'\r\ndn = 'ДН'\r\noutlist = []\r\n\r\n# Разместите код под этой строкой\r\nfor name in names:\r\n\tif stl in name and not pp in name and dv in name:\r\n\t\toutlist.append('Дверной блок стальной внутренний, группы В, ')\r\n\telif stl in name and not pp in name and dn in name:\r\n\t\toutlist.append('Дверной блок стальной наружный, группы А, ')\r\n\telif stl in name and pp in name and dv in name:\r\n\t\toutlist.append('Дверной блок стальной внутренний, группы В, противопожарный, ')\r\n\telif stl in name and pp in name and dn in name:\r\n\t\toutlist.append('Дверной блок стальной наружный, группы А, противопожарный, ')\r\n\telif alm in name and not pp in name and dv in name:\r\n\t\toutlist.append('Внутренний дверной блок из алюминиевого профиля, ')\r\n\telif alm in name and not pp in name and dn in name:\r\n\t\toutlist.append('Наружный дверной блок из алюминиевого профиля, ')\r\n\telif alm in name and pp in name and dv in name:\r\n\t\toutlist.append('Внутренний дверной блок из алюминиевого профиля, противопожарный, ')\r\n\telif alm in name and pp in name and dn in name:\r\n\t\toutlist.append('Наружный дверной блок из алюминиевого профиля, противопожарный, ')\r\n\telif drv in name and dv in name:\r\n\t\toutlist.append('Дверной блок внутренний, ')\r\n\telif drv in name and dn in name:\r\n\t\toutlist.append('Дверной блок наружный, ')\r\n\telif pvh in name and dv in name:\r\n\t\toutlist.append('Дверной блок из ПВХ-профилей внутренний, группы Б, ')\r\n\telif pvh in name and dn in name:\r\n\t\toutlist.append('Дверной блок из ПВХ-профилей наружный, группы А, ')\r\n\telse:\r\n\t\toutlist.append('ТИП БЛОКА НЕ ОПРЕДЕЛЕН/')\r\n# Назначьте вывод переменной OUT.\r\nOUT = outlist",
      "Engine": "IronPython2",
      "VariableInputPorts": true,
      "Id": "33a1476591a740759c6b025a29b14809",
      "Inputs": [
        {
          "Id": "6d11a30456704e51b095533811c14834",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "218121e8ed5144b99b78a6c676379e2b",
          "Name": "OUT",
          "Description": "Результат сценария Python",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Выполнение встроенного сценария Python."
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Загрузить стандартную библиотеку Python и библиотеку DesignScript\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# Введенные в этом узле данные сохраняется в виде списка в переменных IN.\r\nnames = IN[0]\r\napn = 'Ан'\r\napsh = 'Аш'\r\noutlist = []\r\n\r\n# Разместите код под этой строкой\r\nfor name in names:\r\n\tif apn in name:\r\n\t\toutlist.append(' Оборудовать устройством экстренного открывания (\"антипаника\") нажимного типа.')\r\n\telif apsh in name:\r\n\t\toutlist.append(' Оборудовать устройством экстренного открывания (\"антипаника\") типа пуш-бар (ручка-штанга).')\r\n\telse:\r\n\t\toutlist.append('')\r\n# Назначьте вывод переменной OUT.\r\nOUT = outlist",
      "Engine": "IronPython2",
      "VariableInputPorts": true,
      "Id": "33b650e014ef4854a938455844ce0242",
      "Inputs": [
        {
          "Id": "de96dda901264e2886734ee609122d1e",
          "Name": "IN[0]",
          "Description": "Input #0",
